INCLUDE FILE=base.dat
WHOLEMOLECULES ENTITY0=1-164

hlda: COMBINE ARG=d03,d04,d05,d06,d09,d18,d25,d26,d27,d29,d36,d37,d38,d39,d47,d48,d49,d58,d59,d69 COEFFICIENTS=0.2090,-0.4180,0.4178,-0.2003,-0.0556,-0.0295,-0.1237,0.0032,0.0685,-0.2125,0.0513,-0.0355,-0.0845,0.0067,-0.1074,0.0474,0.5158,0.0860,-0.4234,0.1422 PERIODIC=NO


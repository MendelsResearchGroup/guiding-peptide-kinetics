WHOLEMOLECULES ENTITY0=1-155
INCLUDE FILE=base.dat

hlda: COMBINE ARG=d03,d04,d05,d06,d25,d26,d29,d36,d37,d38,d39,d48,d49,d58,d59,d69 COEFFICIENTS=-0.3368,0.4059,-0.3179,0.2501,0.0469,0.0057,0.1180,-0.0678,0.0029,0.0209,0.2433,0.0778,-0.5167,-0.0891,0.3785,-0.2313 PERIODIC=NO

metad: METAD ARG=hlda PACE=25000 HEIGHT=2.8 BIASFACTOR=8 SIGMA=0.008 FILE=HILLS___ID__ GRID_MIN=-1 GRID_MAX=1 ACCELERATION

PRINT ARG=hlda,metad.bias,metad.acc,rmsd,phi7,psi7 FILE=COLVAR___ID__ STRIDE=500
FLUSH STRIDE=500000